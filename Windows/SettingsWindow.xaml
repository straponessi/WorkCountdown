<Window x:Class="WorkCountdown.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙  Настройки — WorkCountdown"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="#0D0D1A" CornerRadius="10" Margin="10"
            BorderBrush="#2A2A4A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20"
                              ShadowDepth="4" Opacity="0.7"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#13132A" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_DragMove">
                <Grid>
                    <TextBlock Text="⚙  Настройки WorkCountdown"
                               Foreground="#606090" FontFamily="Segoe UI"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <Button Content="✕" Click="Cancel_Click"
                            Style="{StaticResource HeaderBtnClose}"
                            Foreground="#606090"
                            HorizontalAlignment="Right" Margin="0,0,4,0"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          MaxHeight="560">
                <StackPanel Margin="20,16,20,4">

                    <TextBlock Text="🕐  Стандартное расписание"
                               Style="{StaticResource SectionLabel}"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Начало (пн – вс)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TbStart" Style="{StaticResource DarkTextBox}"
                                     MaxLength="5" GotFocus="TimeBox_GotFocus"
                                     PreviewTextInput="TimeBox_PreviewInput"
                                     TextChanged="TimeBox_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Конец (пн – чт)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TbEndWd" Style="{StaticResource DarkTextBox}"
                                     MaxLength="5" GotFocus="TimeBox_GotFocus"
                                     PreviewTextInput="TimeBox_PreviewInput"
                                     TextChanged="TimeBox_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Конец (пятница)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TbEndFr" Style="{StaticResource DarkTextBox}"
                                     MaxLength="5" GotFocus="TimeBox_GotFocus"
                                     PreviewTextInput="TimeBox_PreviewInput"
                                     TextChanged="TimeBox_TextChanged"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Foreground="#404060" FontSize="10" FontFamily="Segoe UI"
                               Text="Время московское. Вводите только цифры — двоеточие ставится автоматически."
                               Margin="0,5,0,0" TextWrapping="Wrap"/>

                    <TextBlock Text="📅  Сегодня опоздал?" Style="{StaticResource SectionLabel}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Начало сегодня" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TbCustStart" Style="{StaticResource DarkTextBox}"
                                     MaxLength="5" GotFocus="TimeBox_GotFocus"
                                     PreviewTextInput="TimeBox_PreviewInput"
                                     TextChanged="TimeBox_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Конец сегодня" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TbCustEnd" Style="{StaticResource DarkTextBox}"
                                     MaxLength="5" GotFocus="TimeBox_GotFocus"
                                     PreviewTextInput="TimeBox_PreviewInput"
                                     TextChanged="TimeBox_TextChanged"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Foreground="#404060" FontSize="10" FontFamily="Segoe UI"
                               Text="Применяется только на сегодня. Оставьте пустым — будет стандартное расписание."
                               Margin="0,5,0,0" TextWrapping="Wrap"/>

                    <TextBlock Text="🎨  Цвета и внешний вид" Style="{StaticResource SectionLabel}"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Тема" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbTheme" Style="{StaticResource DarkCombo}"
                                      SelectionChanged="CbTheme_SelectionChanged">
                                <ComboBoxItem Content="dark"  Tag="dark"/>
                                <ComboBoxItem Content="light" Tag="light"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Прозрачность" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="OpacitySlider"
                                        Style="{StaticResource DarkSlider}"
                                        Minimum="0.2" Maximum="1.0" SmallChange="0.05"
                                        ValueChanged="Opacity_Changed"
                                        VerticalAlignment="Center"/>
                                <TextBlock x:Name="OpacityLabel" Grid.Column="1"
                                           Foreground="#9090C0" FontSize="11"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Цвет фона" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="BgSwatch" Grid.Column="0" Height="34"
                                CornerRadius="5" Background="#0D0D1A"
                                Cursor="Hand" MouseLeftButtonDown="BgSwatch_Click">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" BlurRadius="4"
                                                  ShadowDepth="1" Opacity="0.4"/>
                            </Border.Effect>
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="BgHexLabel"
                                   Foreground="#606090" FontFamily="Consolas"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="4" Content="↩ сброс"
                                Style="{StaticResource BtnSecondary}"
                                Padding="10,5" Click="BgReset_Click"/>
                    </Grid>

                    <TextBlock Text="Цвет таймера" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="TimerSwatch" Grid.Column="0" Height="34"
                                CornerRadius="5" Background="#7C6AFF"
                                Cursor="Hand" MouseLeftButtonDown="TimerSwatch_Click">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" BlurRadius="4"
                                                  ShadowDepth="1" Opacity="0.4"/>
                            </Border.Effect>
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="TimerHexLabel"
                                   Foreground="#606090" FontFamily="Consolas"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="4" Content="↩ сброс"
                                Style="{StaticResource BtnSecondary}"
                                Padding="10,5" Click="TimerReset_Click"/>
                    </Grid>

                    <TextBlock Text="⚡  Система" Style="{StaticResource SectionLabel}"/>

                    <CheckBox x:Name="ChkAlwaysOnTop" Style="{StaticResource DarkCheck}"
                              Content="Поверх всех окон"/>
                    <CheckBox x:Name="ChkMinimalist"  Style="{StaticResource DarkCheck}"
                              Content="Минималистичный режим  (прозрачный фон, только таймер)"/>
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <CheckBox x:Name="ChkMiniPct" Style="{StaticResource DarkCheck}"
                                  Content="└─ показывать % и прогресс в мини-режиме"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkAutostart" Style="{StaticResource DarkCheck}"
                              Content="Автозапуск при старте Windows"/>
                    <TextBlock Foreground="#404060" FontSize="10" FontFamily="Segoe UI"
                               Text="Автозапуск вносит запись в HKCU\Software\Microsoft\Windows\CurrentVersion\Run"
                               Margin="0,2,0,8" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#13132A" CornerRadius="0,0,10,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="20,0">
                    <Button Content="✖  Отмена" Style="{StaticResource BtnSecondary}"
                            Click="Cancel_Click" Margin="0,0,10,0"/>
                    <Button Content="💾  Сохранить" Style="{StaticResource BtnPrimary}"
                            Click="Save_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
